{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "baseUrl": ".",
    "moduleResolution": "bundler",
    "paths": {
      "@/*": [
        "src/*"
      ]
    },
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable",
      "ScriptHost"
    ],
    "ignoreDeprecations": "6.0"
  },
  "exclude": [
    "node_modules",
    "dist"
  ]
}